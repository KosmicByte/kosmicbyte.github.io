---
// src/pages/index.astro

import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/Card.astro";
---

<!-- profile2.webp you can remove | Photo <a href="https://unsplash.com/es/@charlesdeluvio?utm_content=creditCopyText&utm_medium=referral&utm_source=unsplash">charlesdeluvio</a> en <a href="https://unsplash.com/es/fotos/hombre-con-gorro-negro-kVg2DQTAK7c?utm_content=creditCopyText&utm_medium=referral&utm_source=unsplash">Unsplash</a>
   -->

<!-- You can replace the card's data with your own here. -->
<BaseLayout title="Aditya Mishra" description="Data engineering consultant building cloud data pipelines across IICS, AWS, and GCP.">
	<Card
	  name="Aditya Mishra"
	  position="Data Engineering Consultant"
	  aboutMe={`Hi there! I'm Aditya — I build and run enterprise-scale cloud data pipelines. Four years at Deloitte specialising in cloud data integration across Informatica IICS, AWS, and GCP, owning delivery from ingestion to production for a leading consumer-electronics and entertainment client. I came up through analytics (Power BI, Python, PySpark), so I build with the people who actually use the data in mind.`}
	  linkedin="https://www.linkedin.com/in/mra36"
	  github="https://github.com/KosmicByte"
	  cvLink="/files/AdityaMishra_CV.pdf"
	  profileImage="/images/profile.png"
	/>
</BaseLayout>

