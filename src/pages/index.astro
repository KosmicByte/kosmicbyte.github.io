   -->

<!-- You can replace the card's data with your own here. -->
<BaseLayout title="Personal Card Portfolio Astro" description="Meta description. Here goes your page description. Provide a clear and concise summary of the content.">
	<Card
	  name="Aditya Mishra"
	  position="ETL Developer"
	  aboutMe={`Hi there! I'm Aditya, a seasoned Data engineering consultant with 4 years of experience at Deloitte, progressing from data analyst to consultant. Specialised in cloud data integration across Informatica Intelligent Cloud Services (IICS), AWS, and GCP, building and supporting enterprise data pipelines for a leading consumer electronics and entertainment client.`}
	  linkedin="https://www.linkedin.com/in/mra36"
	  github="https://github.com/KosmicByte"
	  cvLink="/files/resume-cv.pdf"
	  profileImage="/images/profile2.webp"
	/>
</BaseLayout>

